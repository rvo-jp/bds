# bds の設定ファイルです。
# このファイルを bds.conf にコピーして、サーバーに合わせて編集します。

# Bedrock のインストール先/実行時ディレクトリ。
# BEDROCK_DIR="$BASE_DIR/bedrock-server"

# server.properties の server-name を bds.conf で管理します。
# %v はプレイヤー向け表記、%V は BDS のフル表記に置き換わります。
# 空文字列にすると自動変更しません。
SERVER_NAME_FORMAT="RvoSMP %v"

# 更新確認。timer 関連の値を変えた場合は sudo ./bds.sh restart を再実行します。
CHECK_INTERVAL=6h
UPDATE_NOTICE_SECONDS=300

# バックアップ。BACKUP_ON_CALENDAR を変えた場合は sudo ./bds.sh restart を再実行します。
BACKUP_DIR="$BASE_DIR/backups"
BACKUP_RETENTION_DAYS=14
BACKUP_ON_CALENDAR="*-*-* 04:30:00"
BACKUP_HOLD_SECONDS=10
BACKUP_MIN_FREE_MB=1024

# Discord 通知。Webhook URL を設定する場合、このファイルは Git 管理しないでください。
DISCORD_WEBHOOK_URL=
